<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>

    <!--
        Gestor360 ADMIN
        Reglas de extracción y transferencia de datos
        (Android 12+)
    -->

    <cloud-backup>

        <!-- No respaldar información sensible -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="files" path="." />

    </cloud-backup>

    <device-transfer>

        <!-- No transferir información sensible entre dispositivos -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="files" path="." />

    </device-transfer>

</data-extraction-rules>
